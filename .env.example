# Discourse 配置

# Discourse 基础 URL（例如：https://forum.example.com）
DISCOURSE_BASE_URL=https://your-discourse-instance.com

# Discourse API 密钥（用于服务器端调用 API）
# 在 Discourse 管理面板中创建：Admin > API > Keys
# 需要给予适当的权限（创建帖子、获取帖子等）
DISCOURSE_API_KEY=your_discourse_api_key_here

# Discourse API 用户（用于服务器端调用 API 的默认用户）
# 通常使用 "system" 或管理员用户名
DISCOURSE_API_USER=system

# Discourse Connect 单点登录配置
# 提供者密钥（在 Discourse Admin > Settings > Login 中配置）
DISCOURSE_CONNECT_PROVIDER_SECRET=your_provider_secret_here

# Connect 密钥
DISCOURSE_CONNECT_SECRET=your_connect_secret_here

# Connect 回调 URL
DISCOURSE_CONNECT_CALLBACK_URL=https://your-frontend.com/auth/callback/discourse

# Discourse Webhook 密钥（可选，用于验证 webhook 请求）
DISCOURSE_WEBHOOK_SECRET=your_webhook_secret_here
